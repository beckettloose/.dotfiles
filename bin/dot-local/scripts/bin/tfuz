#!/usr/bin/env bash
#
# Usage: tfuz
#
# Uses fzf to fuzzy search through tmux sessions

set -e
set -u
set -o pipefail

selected=$(tmux list-sessions -F "#{session_name}" | fzf --height 40% --layout reverse --border --border-label="tfuz (tmux fuzzy find)")

# If we are not currently in tmux
if [[ -z $TMUX ]]; then
    tmux attach -d -t="$selected"
    exit 0
fi

# Otherwise, switch to the existing session
tmux switch-client -t "$selected"
